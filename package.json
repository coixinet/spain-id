{
  "name": "spain-id",
  "version": "1.1.14",
  "description": "Spanish id documents validator (NIF, CIF, NIE)",
  "main": "./lib/cjs/index.cjs",
  "module": "./lib/esm/index.mjs",
  "types": "./lib/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/esm/index.mjs",
      "require": "./lib/cjs/index.cjs",
      "types": "./lib/esm/index.d.ts"
    }
  },
  "files": [
    "lib/"
  ],
  "scripts": {
    "test": "jest --passWithNoTests --silent",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "patch": "npm version patch",
    "tsc": "tsc -p tsconfig.json && node -e \"const fs=require('fs');fs.renameSync('./lib/esm/index.js','./lib/esm/index.mjs');\" && tsc -p tsconfig-cjs.json && node -e \"const fs=require('fs');fs.renameSync('./lib/cjs/index.js','./lib/cjs/index.cjs');\"",
    "copy-dts": "node -e \"const fs=require('fs');const d=fs.readFileSync('./src/index.d.ts');fs.writeFileSync('./lib/esm/index.d.ts', d);fs.writeFileSync('./lib/cjs/index.d.ts', d);\"",
    "build": "npm run tsc && npm run copy-dts",
    "tdd": "jest --watchAll",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coixinet/spain-id.git"
  },
  "keywords": [
    "spain",
    "id",
    "nif",
    "dni",
    "cif"
  ],
  "author": "Josep V. Monjo",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/coixinet/spain-id/issues"
  },
  "homepage": "https://github.com/coixinet/spain-id#readme",
  "overrides": {
    "babel-plugin-istanbul": {
      "js-yaml": "^3.14.2"
    },
    "brace-expansion@<1.1.13": "^1.1.13"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "acorn": "^8.17.0",
    "core-js": "^3.49.0",
    "eslint": "^9.39.4",
    "jest": "^30.4.2",
    "kind-of": "^6.0.3",
    "minimist": "^1.2.8",
    "neostandard": "^0.13.0",
    "serialize-javascript": "^7.0.5",
    "typescript": "^6.0.3"
  }
}
